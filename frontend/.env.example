# =====================================================
# GAZLINK — Variables d'environnement Edge Functions
# Copie ce fichier en .env et remplis les valeurs
# NE JAMAIS commiter le fichier .env dans git
# =====================================================

# Supabase (auto-injectées, pas besoin de les définir)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ── Monetbil (Mobile Money Cameroun) ──────────────
# Créer un compte sur https://www.monetbil.com
# Dashboard > Services > Ton service > API Keys
MONETBIL_SERVICE_KEY=
MONETBIL_SERVICE_SECRET=

# URL publique de tes Edge Functions
# Format : https://<project-ref>.supabase.co/functions/v1
GAZLINK_BASE_URL=